<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Registrations</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container">
        <h1 class="mt-5">My Registrations</h1>
        <p class="text-muted">
            View and manage the events you have registered for.
        </p>

        <% if (locals.success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success">
                <%= success_msg %>
            </div>
        <% } %>

        <% if (locals.error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger">
                <%= error_msg %>
            </div>
        <% } %>

        <% if (registrations.length === 0) { %>
            <div class="alert alert-info">
                You have not registered for any events yet.
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Event</th>
                            <th>Category</th>
                            <th>Location</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Registered On</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% registrations.forEach(registration => { %>
                            <tr>
                                <td><%= registration.title %></td>
                                <td><%= registration.category %></td>
                                <td><%= registration.location %></td>

                                <td>
                                    <%= new Date(registration.event_date)
                                        .toLocaleDateString('en-SG') %>
                                </td>

                                <td>
                                    <%= registration.start_time %> -
                                    <%= registration.end_time %>
                                </td>

                                <td>
                                    <%= new Date(registration.registered_at)
                                        .toLocaleString('en-SG') %>
                                </td>

                                <td>
                                    <form
                                        action="/registrations/<%= registration.registration_id %>/delete"
                                        method="POST"
                                        onsubmit="return confirm('Are you sure you want to delete this registration?');"
                                    >
                                        <button type="submit"
                                                class="btn btn-danger btn-sm">
                                            Delete Registration
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>

        <a href="/events" class="btn btn-primary">
            Browse Events
        </a>

        <a href="/dashboard" class="btn btn-secondary">
            Back to Dashboard
        </a>
    </div>
</body>
</html>
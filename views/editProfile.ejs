<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Edit Profile</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" href="/announcement">RP Events</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>

                    <% if (user && user.role==='Student' ) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/attendance">Certificate</a>
                        </li>
                        <% } %>

                            <li class="nav-item">
                                <a class="nav-link active" href="/dashboard">Profile</a>
                            </li>

                </ul>
            </div>

        </div>
    </nav>

    <div class="page-container">

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="card profile-card">
                    <div class="card-body p-4 p-md-5">

                        <div class="text-center mb-4">

                            <div class="profile-avatar">
                                <%= profileUser.full_name.charAt(0).toUpperCase() %>
                            </div>

                            <h2 class="mb-2">Edit Profile</h2>

                            <p class="text-muted mb-0">
                                Update your name and school information
                            </p>

                        </div>

                        <% if (error_msg && error_msg.length> 0) { %>
                            <div class="alert alert-danger">
                                <%= error_msg[0] %>
                            </div>
                            <% } %>

                                <form action="/editProfile/<%= profileUser.student_id %>" method="POST">

                                    <div class="mb-3">
                                        <label for="student_id" class="form-label">
                                            Account ID
                                        </label>

                                        <input type="text" id="student_id" class="form-control"
                                            value="<%= profileUser.student_id %>" disabled>
                                    </div>

                                    <div class="mb-3">
                                        <label for="full_name" class="form-label">
                                            Full Name
                                        </label>

                                        <input type="text" id="full_name" name="full_name" class="form-control"
                                            value="<%= profileUser.full_name %>" required>
                                    </div>

                                    <div class="mb-4">
                                        <label for="school" class="form-label">
                                            School
                                        </label>

                                        <select id="school" name="school" class="form-select" required>
                                            <option value="">-- Select School --</option>

                                            <option value="School of Applied Science (SAS)"
                                                <%=profileUser.school==='School of Applied Science (SAS)' ? 'selected'
                                                : '' %>
                                                >
                                                School of Applied Science (SAS)
                                            </option>

                                            <option value="School of Engineering (SEG)"
                                                <%=profileUser.school==='School of Engineering (SEG)' ? 'selected' : ''
                                                %>
                                                >
                                                School of Engineering (SEG)
                                            </option>

                                            <option value="School of Hospitality (SOH)"
                                                <%=profileUser.school==='School of Hospitality (SOH)' ? 'selected' : ''
                                                %>
                                                >
                                                School of Hospitality (SOH)
                                            </option>

                                            <option value="School of Infocomm (SOI)"
                                                <%=profileUser.school==='School of Infocomm (SOI)' ? 'selected' : '' %>
                                                >
                                                School of Infocomm (SOI)
                                            </option>

                                            <option value="School of Management and Communication (SMC)"
                                                <%=profileUser.school==='School of Management and Communication (SMC)'
                                                ? 'selected' : '' %>
                                                >
                                                School of Management and Communication (SMC)
                                            </option>

                                            <option value="School of Sports, Health and Leisure (SHL)"
                                                <%=profileUser.school==='School of Sports, Health and Leisure (SHL)'
                                                ? 'selected' : '' %>
                                                >
                                                School of Sports, Health and Leisure (SHL)
                                            </option>
                                        </select>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2">

                                        <button type="submit" class="btn btn-primary">
                                            Save Changes
                                        </button>

                                        <a href="/viewProfile/<%= profileUser.student_id %>" class="btn btn-secondary">
                                            Cancel
                                        </a>

                                    </div>

                                </form>

                    </div>
                </div>

            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>
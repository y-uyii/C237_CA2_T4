<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP Events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>
                    <% if (user && user.role === 'Student') { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/attendance">Certificate</a>
                    </li>
                <% } %>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h1 class="mb-3"><%= user.role === 'Admin' ? 'Attendance Roster' : 'My Attendance' %></h1>

        <% if (locals.success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success"><%= success_msg %></div>
        <% } %>

        <% if (locals.error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger"><%= error_msg %></div>
        <% } %>

        <% if (!attendanceList || attendanceList.length === 0) { %>
            <div class="alert alert-info">
                No attendance records found.
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <% if (user.role === 'Admin') { %>
                                <th>Student ID</th>
                                <th>Student Name</th>
                            <% } %>
                            <th>Event</th>
                            <th>Status</th>
                            <th>Check-in Time</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% attendanceList.forEach(record => { %>
                            <tr>
                                <% if (user.role === 'Admin') { %>
                                    <td><%= record.student_id %></td>
                                    <td><%= record.student_name %></td>
                                <% } %>
                                <td><%= record.title %></td>
                                <td>
                                    <span class="badge <%= record.status === 'Present' ? 'bg-success' : (record.status === 'Absent' ? 'bg-danger' : 'bg-secondary') %>">
                                        <%= record.status || 'Pending' %>
                                    </span>
                                </td>
                                <td>
                                    <%= record.checkin_time ? new Date(record.checkin_time).toLocaleString('en-SG') : '-' %>
                                </td>
                                <td>
                                    <% if (user.role === 'Admin') { %>
                                        <form action="/admin/mark-attendance" method="POST" class="d-flex gap-2">
                                            <input type="hidden" name="registration_id" value="<%= record.registration_id %>">
                                            <button type="submit" name="status" value="Present" class="btn btn-sm btn-success">Present</button>
                                            <button type="submit" name="status" value="Absent" class="btn btn-sm btn-danger">Absent</button>
                                        </form>
                                    <% } else if (record.status === 'Present') { %>
                                        <a href="/certificate/<%= record.registration_id %>" class="btn btn-sm btn-primary">View Certificate</a>
                                    <% } else { %>
                                        <span class="text-muted">-</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>

    </div>
</body>
</html>

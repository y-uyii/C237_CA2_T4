<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Announcement</title>
</head>

<body>
        <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>

                     <% if (user && user.role === 'Student') { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/certificate">Certificate</a>
                    </li>
                <% } %>
                
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    
    <div class="container mt-5">
        <h1 class="text-center mb-4">Announcement</h1>
        <div class="d-flex justify-content-between align-items-center mb-4">
        
            <form class="d-flex" action="/" method="GET">
                <select class="form-control me-2" name="filter" aria-label="Filter by category">
                    <option value="">All</option>
                    <option value="Fair">Fair</option>
                    <option value="Sports">Sports</option>
                    <option value="Hackathon">Hackathon</option>
                    <option value="Workshop">Workshop</option>
                </select>
                <button class="btn btn-outline-success" type="submit">Search</button>
            </form>
            
            <% if (user && user.role === 'Admin') { %>
            <a href="/addAnnouncement" class="btn btn-primary">Add Announcement</a>
            <% } %>
        </div>

        <% if (message && message.length > 0) { %>
            <div class="row g-4">
                <% for (let i = 0; i < message.length; i++) { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm h-100 d-flex flex-column">
                            <!-- Image Section -->
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px; overflow: hidden;">
                                <% if (message[i].image) { %>
                                    <img src="/images/<%= message[i].image %>" alt="Announcement Image" class="img-fluid" style="object-fit: cover; width: 100%; height: 100%;">
                                <% } else { %>
                                    <span class="text-muted">No Image</span>
                                <% } %>
                            </div>
                            
                            <!-- Content Section -->
                            <div class="card-body">
                                <h5 class="card-title"><%= message[i].title %></h5>
                                <p class="card-text text-muted">Category: <strong><%= message[i].category %></strong></p>
                            </div>
                            
                            <!-- Buttons-->
                            <div class="card-footer bg-transparent border-top-0 d-flex gap-2 justify-content-center">
                                <a href="/detailAnnouncement/<%= message[i].event_id %>" class="btn btn-outline-info btn-sm">View Details</a>
                                
                                <% if (user && user.role === 'Admin') { %>
                                    <a href="/deleteAnnouncement/<%= message[i].event_id %>"
                                        class="btn btn-outline-danger btn-sm"
                                        onclick="return confirm('Are you sure you want to delete this announcement?')">Delete</a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="alert alert-info text-center">No announcements available.</div>
        <% } %>
    </div>
</body>

</html>

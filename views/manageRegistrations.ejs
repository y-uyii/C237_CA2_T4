<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Registrations</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>

                     <% if (user && user.role === 'Student') { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/certificate">Certificate</a>
                    </li>
                <% } %>
                
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <h1 class="mt-5">Manage Registrations</h1>
        <p class="text-muted">
            View and manage all students registered for events.
        </p>

        <% if (locals.success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success">
                <%= success_msg %>
            </div>
        <% } %>

        <% if (locals.error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger">
                <%= error_msg %>
            </div>
        <% } %>

        <% if (registrations.length === 0) { %>
            <div class="alert alert-info">
                There are currently no event registrations.
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Student ID</th>
                            <th>Student Name</th>
                            <th>Email</th>
                            <th>Event</th>
                            <th>Date</th>
                            <th>Location</th>
                            <th>Registered On</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% registrations.forEach(registration => { %>
                            <tr>
                                <td><%= registration.student_id %></td>
                                <td><%= registration.full_name %></td>
                                <td><%= registration.email %></td>
                                <td><%= registration.title %></td>

                                <td>
                                    <%= new Date(registration.event_date)
                                        .toLocaleDateString('en-SG') %>
                                </td>

                                <td><%= registration.location %></td>

                                <td>
                                    <%= new Date(registration.registered_at)
                                        .toLocaleString('en-SG') %>
                                </td>

                                <td>
                                    <form
                                        action="/admin/registrations/<%= registration.registration_id %>/delete"
                                        method="POST"
                                        onsubmit="return confirm('Are you sure you want to remove this student from the registered event?');"
                                    >
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            Remove Student
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>

        <a href="/events" class="btn btn-primary">
            View Events
        </a>

        <a href="/admin" class="btn btn-secondary">
            Back to Admin Dashboard
        </a>
    </div>
</body>
</html>

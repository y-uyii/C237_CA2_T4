<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Student Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">

            <a class="navbar-brand" href="/announcement">RP Events</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="collapsibleNavbar">

                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>

                    <% if (user && user.role==='Student' ) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/attendance">Certificate</a>
                        </li>
                        <% } %>

                            <li class="nav-item">
                                <a class="nav-link active" href="/dashboard">Profile</a>
                            </li>

                </ul>

            </div>

        </div>
    </nav>

    <div class="container py-5">

        <div class="card shadow">

            <div class="card-body">

                <h1 class="mb-4">Student Dashboard</h1>

                <h3 class="mb-3">
                    Welcome, <%= user.full_name %>!
                </h3>

                <div class="row mb-4">

                    <div class="col-md-6">
                        <p>
                            <strong>Your Role:</strong>
                            <%= user.role %>
                        </p>
                    </div>

                    <div class="col-md-6">
                        <p>
                            <strong>Your School:</strong>
                            <%= user.school %>
                        </p>
                    </div>

                </div>

                <hr>

                <h4 class="mb-3">Account Management</h4>

                <div class="d-flex flex-wrap gap-2">

                    <a href="/viewProfile/<%= user.student_id %>" class="btn btn-primary">
                        View My Full Profile
                    </a>

                    <a href="/editProfile/<%= user.student_id %>" class="btn btn-warning">
                        Edit Profile
                    </a>

                    <form action="/logout" method="POST">
                        <button type="submit" class="btn btn-danger">
                            Logout
                        </button>
                    </form>

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>
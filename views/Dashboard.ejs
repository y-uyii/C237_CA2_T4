<!DOCTYPE html>
<html>
<head>
    <title>Student Dashboard</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <h1>Student Dashboard</h1>
    
    <h2>Welcome, <%= user.full_name %>!</h2>
    <p>Your Role: <strong><%= user.role %></strong></p>
    <p>Your School: <%= user.school %></p>

    <hr>

    <h3>Account Management</h3>
    <ul>
        <li><a href="/viewProfile/<%= user.student_id %>">View My Full Profile</a></li>
        <li><a href="/editProfile/<%= user.student_id %>">Edit Profile</a></li>
    </ul>

    <hr>

    <h3>Event Actions</h3>
    <ul>
        <li><a href="/events">Browse / Search Events</a></li>
    </ul>

    <hr>

    <form action="/logout" method="POST">
        <button type="submit">Logout</button>
    </form>
</body>
</html>

<!DOCTYPE html>
<html>

<head>
    <title>
        <%= event.title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <h1 class="mt-5">
            <%= event.title %>
        </h1>
        <p class="text-muted">
            <%= event.category %>
        </p>

        <% if (locals.success_msg && success_msg.length> 0) { %>
            <div class="alert alert-success">
                <%= success_msg %>
            </div>
            <% } %>

                <% if (locals.error_msg && error_msg.length> 0) { %>
                    <div class="alert alert-danger">
                        <%= error_msg %>
                    </div>
                    <% } %>

                        <table class="table table-bordered mt-3">
                            <tr>
                                <th>Description</th>
                                <td>
                                    <%= event.description %>
                                </td>
                            </tr>
                            <tr>
                                <th>Location</th>
                                <td>
                                    <%= event.location %>
                                </td>
                            </tr>
                            <tr>
                                <th>Date</th>
                                <td>
                                    <%= event.event_date.toISOString().split('T')[0] %>
                                </td>
                            </tr>
                            <tr>
                                <th>Time</th>
                                <td>
                                    <%= event.start_time %> - <%= event.end_time %>
                                </td>
                            </tr>
                            <tr>
                                <th>Capacity</th>
                                <td>
                                    <%= event.capacity %>
                                </td>
                            </tr>
                        </table>

                        <% if (user && user.role==='Student' ) { %>
                            <form action="/events/<%= event.event_id %>/register" method="POST" style="display:inline;">

                                <button type="submit" class="btn btn-success">
                                    Register
                                </button>
                            </form>

                            <a href="/registrations" class="btn btn-primary">
                                My Registrations
                            </a>
                            <% } %>

                                <hr>

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h3>Activity Schedule</h3>

                                    <% if (user && user.role==='Admin' ) { %>
                                        <a href="/events/<%= event.event_id %>/activities/new" class="btn btn-primary">
                                            Add Activity
                                        </a>
                                        <% } %>
                                </div>

                                <% if (activities.length===0) { %>

                                    <p>No activities have been added for this event.</p>

                                    <% } else { %>

                                        <table class="table table-bordered">
                                            <thead>
                                                <tr>
                                                    <th>Activity</th>
                                                    <th>Date</th>
                                                    <th>Time</th>
                                                    <th>Location</th>
                                                    <th>Category</th>

                                                    <% if (user && user.role==='Admin' ) { %>
                                                        <th>Actions</th>
                                                        <% } %>
                                                </tr>
                                            </thead>

                                            <tbody>
                                                <% activities.forEach(activity=> { %>
                                                    <tr>
                                                        <td>
                                                            <%= activity.activity_name %>
                                                        </td>

                                                        <td>
                                                            <%= activity.activity_date.toISOString().split('T')[0] %>
                                                        </td>

                                                        <td>
                                                            <%= activity.start_time %> - <%= activity.end_time %>
                                                        </td>

                                                        <td>
                                                            <%= activity.activity_location %>
                                                        </td>

                                                        <td>
                                                            <%= activity.activity_category %>
                                                        </td>

                                                        <% if (user && user.role==='Admin' ) { %>
                                                            <td>
                                                                <a href="/activities/<%= activity.activity_id %>/edit"
                                                                    class="btn btn-sm btn-warning">
                                                                    Edit
                                                                </a>

                                                                <form
                                                                    action="/activities/<%= activity.activity_id %>/delete"
                                                                    method="POST" style="display:inline;"
                                                                    onsubmit="return confirm('Delete this activity?');">

                                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                                        Delete
                                                                    </button>
                                                                </form>
                                                            </td>
                                                            <% } %>
                                                    </tr>
                                                    <% }) %>
                                            </tbody>
                                        </table>

                                        <% } %>

                                            <% if (user && user.role==='Admin' ) { %>
                                                <a href="/events/<%= event.event_id %>/edit"
                                                    class="btn btn-warning">Edit</a>

                                                <form action="/events/<%= event.event_id %>/delete" method="POST"
                                                    style="display:inline;"
                                                    onsubmit="return confirm('Delete this event?');">

                                                    <button type="submit" class="btn btn-danger">Delete</button>
                                                </form>

                                                <a href="/admin/registrations" class="btn btn-primary">
                                                    Manage Registrations
                                                </a>
                                                <% } %>

                                                    <a href="/events" class="btn btn-secondary">Back to Events</a>
    </div>
</body>
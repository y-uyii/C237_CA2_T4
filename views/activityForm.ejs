<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        <%= activity ? 'Edit Activity' : 'Add Activity' %>
    </title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <div class="card shadow">
                <div class="card-body p-4">

                    <h2 class="mb-2">
                        <%= activity ? 'Edit Activity' : 'Add Activity' %>
                    </h2>

                    <p class="text-muted mb-4">
                        Event: <strong><%= event.title %></strong>
                    </p>

                    <% if (error_msg && error_msg.length > 0) { %>
                        <div class="alert alert-danger">
                            <%= error_msg[0] %>
                        </div>
                    <% } %>

                    <form action="<%= formAction %>" method="POST">

                        <div class="mb-3">
                            <label for="activity_name" class="form-label">
                                Activity Name
                            </label>

                            <input
                                type="text"
                                id="activity_name"
                                name="activity_name"
                                class="form-control"
                                value="<%= activity ? activity.activity_name : '' %>"
                                required
                            >
                        </div>

                        <div class="mb-3">
                            <label for="activity_description" class="form-label">
                                Activity Description
                            </label>

                            <textarea
                                id="activity_description"
                                name="activity_description"
                                class="form-control"
                                rows="4"
                                required
                            ><%= activity ? activity.activity_description : '' %></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="activity_category" class="form-label">
                                Activity Category
                            </label>

                            <input
                                type="text"
                                id="activity_category"
                                name="activity_category"
                                class="form-control"
                                value="<%= activity ? activity.activity_category : '' %>"
                                placeholder="Example: Workshop, Sports, Registration"
                                required
                            >
                        </div>

                        <div class="mb-3">
                            <label for="activity_date" class="form-label">
                                Activity Date
                            </label>

                            <input
                                type="date"
                                id="activity_date"
                                name="activity_date"
                                class="form-control"
                                value="<%= activity && activity.activity_date
                                    ? new Date(activity.activity_date).toISOString().split('T')[0]
                                    : ''
                                %>"
                                required
                            >
                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label for="start_time" class="form-label">
                                    Start Time
                                </label>

                                <input
                                    type="time"
                                    id="start_time"
                                    name="start_time"
                                    class="form-control"
                                    value="<%= activity ? activity.start_time : '' %>"
                                    required
                                >
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="end_time" class="form-label">
                                    End Time
                                </label>

                                <input
                                    type="time"
                                    id="end_time"
                                    name="end_time"
                                    class="form-control"
                                    value="<%= activity ? activity.end_time : '' %>"
                                    required
                                >
                            </div>

                        </div>

                        <div class="mb-4">
                            <label for="activity_location" class="form-label">
                                Activity Location
                            </label>

                            <input
                                type="text"
                                id="activity_location"
                                name="activity_location"
                                class="form-control"
                                value="<%= activity ? activity.activity_location : '' %>"
                                required
                            >
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <%= activity ? 'Update Activity' : 'Add Activity' %>
                        </button>

                        <a
                            href="/events/<%= event.event_id %>"
                            class="btn btn-secondary"
                        >
                            Cancel
                        </a>

                    </form>

                </div>
            </div>

        </div>
    </div>

</div>

</body>
</html>

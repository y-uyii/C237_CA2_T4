<!-- product.ejs -->

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Announcement</title>
</head>

<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container">
        <br>
        <div class="text-center">
            <h2>Announcement details</h2>
        </div>
        <br>
        <% if (message) { %>
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Image Section (Left Side) -->
                        <div class="col-md-6">
                            <div class="bg-light d-flex align-items-center justify-content-center rounded"
                                style="height: 400px; overflow: hidden;">
                                <% if (message.image) { %>
                                    <img src="<%= message.image %>" alt="Announcement Image" class="img-fluid"
                                        style="object-fit: cover; width: 100%; height: 100%;">
                                    <% } else { %>
                                        <span class="text-muted">No Image Available</span>
                                        <% } %>
                            </div>
                        </div>

                        <!-- Details Section (Right Side) -->
                        <div class="col-md-6">
                            <div class="d-flex flex-column h-100">
                                <h3 class="mb-3">
                                    <%= message.title %>
                                </h3>
                                <p class="mb-3"><b>Category:</b><br> <span class="badge bg-info text-dark">
                                        <%= message.category %>
                                    </span></p>
                                <p><b>Details:</b><br>
                                    <%= message.description %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% if (user && user.role==='admin' ) { %>
                <div class="mt-3 d-flex gap-2">
                    <a href="/updateAnnouncement/<%= id %>" class="btn btn-outline-secondary btn-sm">Edit</a>
                    <a href="/" class="btn btn-outline-dark btn-sm">Back</a>
                </div>
                <% } else { %>
                    <p>No announcement found.</p>
                    <% } %>
</body>

</html>
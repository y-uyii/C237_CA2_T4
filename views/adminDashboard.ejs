<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" href="/announcement">RP Events</a>

            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#collapsibleNavbar"
            >
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>

                    <% if (user && user.role === 'Student') { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/attendance">Certificate</a>
                        </li>
                    <% } %>

                    <li class="nav-item">
                        <a class="nav-link active" href="/dashboard">Profile</a>
                    </li>

                </ul>
            </div>

        </div>
    </nav>

    <div class="container py-5">

        <% if (success_msg && success_msg.length> 0) { %>
            <div class="alert alert-success">
                <%= success_msg[0] %>
            </div>
            <% } %>

                <% if (error_msg && error_msg.length> 0) { %>
                    <div class="alert alert-danger">
                        <%= error_msg[0] %>
                    </div>
                    <% } %>

                        <div class="card shadow-sm border-0">

                            <div class="card-body p-4 p-md-5">

                                <div
                                    class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">

                                    <div>
                                        <h1 class="mb-2">Admin Control Panel</h1>

                                        <h3 class="text-muted mb-2">
                                            Welcome back, <%= user.full_name %>!
                                        </h3>

                                        <span class="badge text-bg-success">
                                            System Online
                                        </span>
                                    </div>

                                    <div class="mt-3 mt-md-0">
                                        <span class="badge text-bg-dark fs-6">
                                            <%= user.role %>
                                        </span>
                                    </div>

                                </div>

                                <hr class="my-4">

                                <h4 class="mb-3">Quick Actions</h4>

                                <div class="row g-3 mb-4">

                                    <div class="col-md-4">
                                        <a href="/events/new" class="btn btn-primary w-100 py-3">
                                            Create Event
                                        </a>
                                    </div>

                                    <div class="col-md-4">
                                        <a href="/events" class="btn btn-outline-primary w-100 py-3">
                                            Manage Events
                                        </a>
                                    </div>

                                    <div class="col-md-4">
                                        <a href="/registration" class="btn btn-outline-secondary w-100 py-3">
                                            Manage Registrations
                                        </a>
                                    </div>

                                    <div class="col-md-4">
                                        <a href="/events" class="btn btn-outline-success w-100 py-3">
                                            Manage Attendance
                                        </a>
                                    </div>

                                    <div class="col-md-4">
                                        <a href="/announcement" class="btn btn-outline-info w-100 py-3">
                                            Announcements
                                        </a>
                                    </div>

                                    <div class="col-md-4">
                                        <a href="/addAnnouncement" class="btn btn-outline-dark w-100 py-3">
                                            Add Announcement
                                        </a>
                                    </div>

                                    <div class="col-md-4">
                                        <a href="/admin/users" class="btn btn-outline-secondary w-100 py-3">
                                            Manage Users
                                        </a>
                                    </div>

                                </div>

                                <hr class="my-4">

                                <h4 class="mb-3">Account Management</h4>

                                <div class="d-flex flex-wrap gap-2">

                                    <a href="/viewProfile/<%= user.student_id %>" class="btn btn-primary">
                                        View My Admin Profile
                                    </a>

                                    <a href="/editProfile/<%= user.student_id %>" class="btn btn-warning">
                                        Edit Profile
                                    </a>

                                    <form action="/logout" method="POST">
                                        <button type="submit" class="btn btn-danger">
                                            Logout
                                        </button>
                                    </form>

                                </div>

                            </div>

                        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>

<!DOCTYPE html>
<html>
<head>
    <title>Certificate of Attendance</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    
    <div class="container">
        <div class="mt-4">
            <a href="/" class="btn btn-outline-secondary">Back to Dashboard</a>
        </div>
        <div class="border border-3 p-5 mt-4 text-center" style="border-color: #b8860b !important;">
            <h2 class="text-uppercase">Certificate of Attendance</h2>
            <p class="mt-4 mb-1">This certifies that</p>
            <h1 class="my-3"><%= cert.student_name %></h1>
            <p class="mb-1">has attended</p>
            <h3 class="my-3"><%= cert.event_name %></h3>
            <p class="mt-4">Date: <%= new Date(cert.event_date).toLocaleDateString() %></p>
        </div>
    </div>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Announcement</title>
</head>
<body>
      <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    
    <div class="container mt-4">
    <h2 class="text-center mb-4">Update Announcement</h2>
    
    <% if (message) { %>
      <form action="/updateAnnouncement/<%= id %>" method="POST" class="mx-auto" style="max-width: 500px;">
        
        <div class="mb-3">
          
          <% if (message.image) { %>
            Current Image:
            <br>
            <img src="<%= message.image %>" alt="Current Image" class="img-fluid mt-2" style="max-height: 200px;">
          <% } else { %>
            <p class="text-muted mt-2">No image available.</p>
          <% } %>
          <br>
          <input type="file" class="form-control" id="image" name="image">
        </div>

        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input type="text" class="form-control" id="title" name="title" value="<%= message.title %>" required>
        </div>

        <div class="mb-3">
          <label for="category" class="form-label">Category</label>
          <input type="text" class="form-control" id="category" name="category" value="<%= message.category %>" required>
        </div>

        <div class="mb-3">
          <label for="details" class="form-label">Details</label>
          <textarea class="form-control" id="details" name="details" rows="4" required><%= message.details %></textarea>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary">Update Announcement</button>
          <a href="/" class="btn btn-secondary">Back to Announcements</a>
        </div>
      </form>
    <% } else { %>
      <p class="text-center">No product found.</p>
    <% } %>
  </div>
</body>
</html>
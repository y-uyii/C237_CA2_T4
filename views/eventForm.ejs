<!DOCTYPE html>
<html>

<head>
    <title>
        <%= event ? 'Edit Event' : 'Create New Event' %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP Events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>

                    <% if (user && user.role==='Student' ) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/attendance">Certificate</a>
                        </li>
                        <% } %>

                            <li class="nav-item">
                                <a class="nav-link" href="/dashboard">Profile</a>
                            </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <h1 class="mt-5">
            <%= event ? 'Edit Event' : 'Create New Event' %>
        </h1>
        <p><a href="/events">Back to Events</a></p>

        <% if (locals.error_msg && error_msg.length> 0) { %>
            <div class="alert alert-danger">
                <%= error_msg %>
            </div>
            <% } %>

                <form action="<%= event ? '/events/' + event.event_id + '/edit' : '/events/new' %>" method="POST" >
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" class="form-control" id ="title" name="title" value="<%= event ? event.title : '' %>"
                            required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="description"
                            rows="4"><%= event ? event.description : '' %></textarea>
                    </div>
                    <div class="mb-3">
                        <div class="mb-3">
                            <label class="form-label">Category</label>

                            <select class="form-select" name="category" required>
                                <option value="">-- Select Category --</option>

                                <option value="Workshop" <%=event && event.category==='Workshop' ? 'selected' : '' %>>
                                    Workshop
                                </option>

                                <option value="Seminar" <%=event && event.category==='Seminar' ? 'selected' : '' %>>
                                    Seminar
                                </option>

                                <option value="Competition" <%=event && event.category==='Competition' ? 'selected' : ''
                                    %>>
                                    Competition
                                </option>

                                <option value="Sports" <%=event && event.category==='Sports' ? 'selected' : '' %>>
                                    Sports
                                </option>

                                <option value="Volunteer" <%=event && event.category==='Volunteer' ? 'selected' : '' %>>
                                    Volunteer
                                </option>

                                <option value="Networking" <%=event && event.category==='Networking' ? 'selected' : ''
                                    %>>
                                    Networking
                                </option>

                                <option value="Career" <%=event && event.category==='Career' ? 'selected' : '' %>>
                                    Career
                                </option>

                                <option value="Academic" <%=event && event.category==='Academic' ? 'selected' : '' %>>
                                    Academic
                                </option>

                                <option value="Others" <%=event && event.category==='Others' ? 'selected' : '' %>>
                                    Others
                                </option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <input type="text" class="form-control" name="location"
                            value="<%= event ? event.location : '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" name="event_date"
                            value="<%= event && event.event_date ? new Date(event.event_date).toISOString().slice(0,10) : '' %>"
                            required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Start Time</label>
                        <input type="time" class="form-control" name="start_time"
                            value="<%= event && event.start_time ? event.start_time.slice(0,5) : '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">End Time</label>
                        <input type="time" class="form-control" name="end_time"
                            value="<%= event && event.end_time ? event.end_time.slice(0,5) : '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Capacity</label>
                        <input type="number" class="form-control" name="capacity"
                            value="<%= event ? event.capacity : '' %>" min="1" required>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <%= event ? 'Save Changes' : 'Create Event' %>
                    </button>
                </form>
    </div>
</body>

</html>
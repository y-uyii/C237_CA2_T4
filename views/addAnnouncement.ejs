<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>RP event</title>
  <link rel="stylesheet" href="/css/style.css"> 
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/announcement">RP Events</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/registration">Registration</a>
                    </li>

                    <% if (user && user.role === 'Student') { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/attendance">Certificate</a>
                    </li>
                <% } %>
                    
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

  <!-- Main Content -->
<div class="card-body p-4">

    <form action="/addAnnouncement" method="POST">

        <div class="mb-4">
            <label class="form-label fw-bold">
                Select Event
            </label>

            <select name="eventId" class="form-select" required>

                <option value="" selected disabled>
                    -- Choose an Event --
                </option>

                <% events.forEach(event => { %>
                    <option value="<%= event.event_id %>">
                        <%= event.title %>
                    </option>
                <% }) %>

            </select>

            <div class="form-text">
                Select an event to publish as an announcement.
            </div>
        </div>


        <div class="d-grid">
            <button type="submit" class="btn btn-primary btn-lg">
                Create Announcement
            </button>
        </div>

    </form>

</div>
</body>
</html>
